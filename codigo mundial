 ["CAN","Canadá","🇨🇦","B",0,1572],["BIH","Bosnia","🇧🇦","B",1,1470],["QAT","Catar","🇶🇦","B",2,1450],["SUI","Suiza","🇨🇭","B",3,1655],
 ["BRA","Brasil","🇧🇷","C",0,1772],["MAR","Marruecos","🇲🇦","C",1,1770],["HAI","Haití","🇭🇹","C",2,1320],["SCO","Escocia","🏴","C",3,1504],
