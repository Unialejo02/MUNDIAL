/* ---------- estado ---------- */
let STATE=Store.get(KEY)||{results:{},eloOverride:{}};
if(!STATE.results||Object.keys(STATE.results).length===0){STATE.results=JSON.parse(JSON.stringify(SEED));}
function save(){Store.set(KEY,STATE)}

/* ---------- Elo actual: base + réplica de todos los resultados ---------- */
let ELO={};
function recomputeElo(){
  ELO={}; TEAMS.forEach(t=>ELO[t[0]]= (STATE.eloOverride[t[0]]!=null?STATE.eloOverride[t[0]]:t[5]));
  // replay en orden jornada->grupo para determinismo
  const ids=Object.keys(STATE.results).sort();
  ids.forEach(id=>{
    const fx=FIXTURES.find(f=>f.id===id); if(!fx)return;
    const r=STATE.results[id]; if(!r)return;
    const [gh,ga]=r; const Ra=ELO[fx.home],Rb=ELO[fx.away];
    const We=1/(Math.pow(10,(Rb-Ra)/400)+1);
    let W = gh>ga?1:(gh<ga?0:0.5);
    const gd=Math.abs(gh-ga); let G=1; if(gd===2)G=1.5; else if(gd>=3)G=(11+gd)/8;
    const K=50;
    const delta=K*G*(W-We);
    ELO[fx.home]=Ra+delta; ELO[fx.away]=Rb-delta;
  });
}
function elo(code){return ELO[code]}

/* ---------- motor Poisson ---------- */
function poissonPMF(lambda,k){let p=Math.exp(-lambda);for(let i=1;i<=k;i++)p*=lambda/i;return p}
function pGE(mean,k){let c=0;for(let n=0;n<k;n++)c+=poissonPMF(mean,n);return Math.max(0,1-c)} // P(X>=k)
function predict(aCode,bCode,homeAdv){
  let Ra=elo(aCode), Rb=elo(bCode);
  if(homeAdv)Ra+=60;
  const dr=Ra-Rb;
  const We=1/(Math.pow(10,-dr/400)+1);          // expectativa local
  const G0=1.32, beta=0.85;                      // media de goles base por equipo
  const ex=beta*dr/400;                          // ventaja según Elo
  let lamA=Math.max(0.20,Math.min(5,G0*Math.exp(ex)));   // goles esperados local
  let lamB=Math.max(0.20,Math.min(5,G0*Math.exp(-ex)));  // goles esperados visita
  const N=10; const pa=[],pb=[]; let spa=0,spb=0;
  for(let i=0;i<N;i++){const a=poissonPMF(lamA,i),b=poissonPMF(lamB,i);pa.push(a);pb.push(b);spa+=a;spb+=b;}
  const mass=spa*spb;
  let pH=0,pD=0,pA=0,o15=0,o25=0,o35=0,btts=0,hA2=0,best={p:-1,i:0,j:0};
  const exact=[];
  for(let i=0;i<N;i++)for(let j=0;j<N;j++){
    const p=pa[i]*pb[j];
    if(i>j)pH+=p; else if(i===j)pD+=p; else pA+=p;
    if(i+j>=2)o15+=p;
    if(i+j>=3)o25+=p;
    if(i+j>=4)o35+=p;
    if(i>=1&&j>=1)btts+=p;
    if(i-j>=2)hA2+=p;                            // local gana por 2+ (hándicap -1.5)
    if(p>best.p)best={p,i,j};
    exact.push({i,j,p});
  }
  const nm=x=>x/mass;
  pH=nm(pH);pD=nm(pD);pA=nm(pA);o15=nm(o15);o25=nm(o25);o35=nm(o35);btts=nm(btts);hA2=nm(hA2);
  const aScore=1-pa[0]/spa, bScore=1-pb[0]/spb;
  const csA=pb[0]/spb, csB=pa[0]/spa;            // portería a cero = el rival no marca
  exact.forEach(e=>e.p=e.p/mass); exact.sort((x,y)=>y.p-x.p);
  /* córners: dominio territorial, base 8.5 por partido (verif. Mundial 2026) */
  const cTot=8.5+0.6*Math.abs(lamA-lamB);
  const sA=Math.pow(lamA,0.85),sB=Math.pow(lamB,0.85);
  const cornA=cTot*sA/(sA+sB),cornB=cTot-cornA;
  /* tarjetas: más en partidos parejos; base ~4 amarillas/partido */
  const even=1-2*Math.abs(We-0.5);
  const kTot=3.2+2.0*even, tilt=0.10*(2*We-1);
  const cardA=kTot*(0.5-tilt),cardB=kTot*(0.5+tilt);
  const redMean=0.14+0.14*even;
  return {Ra,Rb,lamA,lamB,We,pH,pD,pA,o15,o25,o35,btts,aScore,bScore,csA,csB,hA15:hA2,
          best,exact:exact.slice(0,5),over:o25,
          corners:{tot:cTot,a:cornA,b:cornB,o75:pGE(cTot,8),o85:pGE(cTot,9),o95:pGE(cTot,10),o105:pGE(cTot,11)},
          cards:{tot:kTot,a:cardA,b:cardB,o35:pGE(kTot,4),o45:pGE(kTot,5),o55:pGE(kTot,6),red:1-Math.exp(-redMean)}};
}
const pct=x=>Math.round(x*100);

/* ---------- render: tarjeta de predicción ---------- */
function predCardHTML(aCode,bCode,homeAdv,opts){
