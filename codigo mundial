});

/* resultados verificados precargados [home,away] */
const SEED={
 "A-2-0":[1,0],"A-2-1":[1,1],
 "E-2-0":[2,1],"E-2-1":[1,1],
 "F-1-0":[2,2],"F-2-0":[5,1],
